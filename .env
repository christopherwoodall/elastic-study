ENVIRONMENT="development"
STRICT_MODE="true"

TARGET_URL="https://openrouter.ai/api/v1"

ELASTIC_VERSION=9.0.0
ELASTIC_URL="http://localhost:9200"

# Agent Indexes
ELASTIC_INDEX="agent-proxy-logs"

# Benchmarking Indexes
BENCHMARK_INDEX="llm-benchmarks"

# RAG Indexes
RAG_KB_INDEX="rag-knowledge-base"
RAG_LOG_INDEX="rag-observability-logs"

# Relative to the --working-dir passed to the opencode command
OPENCODE_CONFIG_DIR="../configs/"
OPENCODE_CONFIG="../configs/opencode.jsonc"
