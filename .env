# ==========================================
# CORE CONFIGURATION
# ==========================================
ENVIRONMENT="development"
STRICT_MODE="true"

TARGET_URL="https://openrouter.ai/api/v1"

# ==========================================
# ELASTICSEARCH SETTINGS
# ==========================================
ELASTIC_VERSION="9.0.0"
ELASTIC_URL="http://localhost:9200"

# --- Indexes ---
ELASTIC_INDEX="agent-proxy-logs"
BENCHMARK_INDEX="llm-benchmarks"
RAG_KB_INDEX="rag-knowledge-base"
RAG_LOG_INDEX="rag-observability-logs"

# ==========================================
# REPLAY LOGS & DATASETS
# ==========================================
REPLAY_INDEX="logs-endpoint.events-simulated"

# Base URL for Log4Shell Datasets
REPLAY_LOG_BASE_URL="https://raw.githubusercontent.com/OTRF/Security-Datasets/master/datasets/compound/Log4Shell/"

# Dataset Files (Wrapped in single quotes to allow internal spaces/formatting)
REPLAY_LOG_HOST_FILES=[ "syslog_auoms_auditd_log4shell_cve2021_44228_jndi_reference.zip", "syslog_sysmon_log4shell_cve2021_44228_jndi_reference.zip"]
REPLAY_LOG_NET_FILES=["pcap_log4shell_cve2021_44228_jndi_reference.zip" ]

# --- Unused/Archived Files ---
# Network: vminsights_vmconnection_log4shell_cve2021_44228_jndi_reference.zip

# ==========================================
# OPENCODE PATHS
# ==========================================
# Note: Relative to the --working-dir passed to the opencode command
OPENCODE_CONFIG_DIR="../configs/"
OPENCODE_CONFIG="../configs/opencode.jsonc"
